#general docker
CONFIG=/path/to/docker/config
PUID=1000 # in terminal, type `id`
PGID=1000 # in terminal, type `id`
TZ=Europe/London #Your timezone for logs

#gluetun specific variables (most common)
##For all possible variables and how to use, go to: https://github.com/qdm12/gluetun-wiki/blob/main/setup/readme.md#setup
VPN_SERVICE_PROVIDER=
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
SERVER_COUNTRIES=
VPN_PORT_FORWARDING=on
QBT_WEBUI_ENABLED=true
GLUETUN_USER=whateveryouwant
GLUETUN_PASS=pleasechangeME

#qbittorrent specific variables (most common)
WEBUI_PORT=8080

#Gluetun Synchronised Port (GSP) qbittorrent mod
GSP_QBITTORRENT_PORT=53764 #gluetun and GSP will automatically update this port for you!
GSP_MINIMAL_LOGS=false #Change to true once you get everything working
GSP_GTN_API_KEY= #`openssl rand -hex 32` is sufficient. MANDATORY: please see this URL for how this is used and why: https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/control-server.md#authentication

#Byparr
BYPARR_LOG_LEVEL=info #Byparr log verbosity

#bt4g (base)
BT4G_BYPARR=http://localhost:8191/v1 #Byparr endpoint, e.g. `http://localhost:8191/v1`. When set, the plugin prefers the solver to clear Cloudflare
BT4G_UPDATE_TRACKERS=1 #Automatically update magnet trackers from https://raw.githubusercontent.com/ngosang/trackerslist/master/trackers_best.txt
BT4G_MAX_PAGES=3 #bt4g returns 15 results per page, this would return 45 results maximum
BT4G_MIN_DELAY=1.5 #Minimum seconds to wait between requests (lower bound of the randomized human-like delay)
BT4G_MAX_DELAY=4.0 #Maximum seconds to wait between requests (upper bound of the randomized human-like delay)
BT4G_LOG_LEVEL=ERROR #`DEBUG` / `INFO` / `WARNING` / `ERROR` / `CRITICAL` (case-insensitive) or numeric. Use `DEBUG` for verbose tracing while testing
BT4G_LOG_FILE=/config/bt4gprx.log #Path for a tailable log. Set to `""` to disable file logging

#bt4g (optional)
BT4G_BASE_URL=https://bt4gprx.com #Override the site base URL if the domain changes or you use a mirror
BT4G_FS_TIMEOUT_MS=60000 #Solver `maxTimeout` in milliseconds. Raise it if the solver needs longer to clear a challenge
BT4G_PAGE_PARAM=p #Query param name for pagination. Set to `""` to disable paging (single page)
BT4G_SORT_PARAM=orderby #Query param name for sorting. Set to `""` to drop sorting (site default order)
BT4G_SORT_VALUE=seeders #Value for the sort param
##These settings should not be used if using the `BT4G_BYPARR`!
BT4G_CF_CLEARANCE= #Manually solved Cloudflare `cf_clearance` cookie value. When set, the plugin skips the solver and sends this cookie on direct requests. Bound to IP + User-Agent + TLS fingerprint and expires (~30 min); solve from the same exit IP and set `BT4G_USER_AGENT` to match. `curl_cffi` strongly recommended (its browser TLS fingerprint helps the cookie pass)
BT4G_COOKIE= #Full raw `Cookie` header to send instead (overrides `BT4G_CF_CLEARANCE`)
BT4G_USER_AGENT= #User-Agent to send; MUST match the browser that solved the challenge when using `BT4G_CF_CLEARANCE`
BT4G_IMPERSONATE=chrome #`curl_cffi` impersonation target (e.g. `chrome`, `chrome124`, `safari17`)